<Handler 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../Environement.xsd">

    <!-- Lit le body JSON. Ex: {"name":"Alice","email":"alice@example.com"} -->
    <!-- Les champs sont disponibles directement : {{name}}, {{email}}, etc. -->
    <BodyRead Var="body" />

    <SqlExecute Source="MyDB1" Var="rowsAffected">
      <Query>
        <Insert Table="Customer">
          <Values>
            <NAME>{{Name}}</NAME>
          </Values>
        </Insert>
      </Query>
    </SqlExecute>

    <Return Status="201">
        <Data Var="body" />
    </Return>

</Handler>